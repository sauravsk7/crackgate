# ─────────────────────────────────────────────────────────────────────────────
# CrackGate Terraform values
# Copy to terraform.tfvars and fill. NEVER commit terraform.tfvars.
# ─────────────────────────────────────────────────────────────────────────────

# Your home/office public IPv4 in CIDR form. Used to scope SSH (port 22).
# Find with: curl -s ifconfig.me
admin_ip_cidr = "203.0.113.42/32"

# Public SSH key authorized to log into the EC2 'deploy' user.
# Paste the contents of ~/.ssh/id_ed25519.pub (or whichever key you'll use).
deploy_ssh_pubkey = "ssh-ed25519 AAAA... vikas@laptop"

# Optional overrides — defaults are fine for $32/mo target
# aws_region                = "ap-south-1"
# ec2_instance_type         = "t4g.small"
# rds_instance_class        = "db.t4g.micro"
# rds_allocated_storage_gb  = 20
# rds_backup_retention_days = 7
# domain                    = "crackgate.in"
# github_org                = "ydvikasiitkgp-arch"
# github_repo               = "crackgate"
