// CrackGate — Prisma schema
// Designed for AWS Aurora Serverless v2 (Postgres 15+).

generator client {
  provider      = "prisma-client-js"
  // Emit into the package itself so workspace consumers (apps/frontend, apps/backend)
  // resolve the engine binary deterministically regardless of npm hoisting.
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"] // native + AWS Lambda RHEL + Alpine (Docker) x64 & arm64
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  premium
}

enum Role {
  user
  admin
}

enum AttemptKind {
  mock
  pyq
}

enum UpiClaimStatus {
  pending
  approved
  rejected
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?    // required by @auth/prisma-adapter
  picture       String?    // legacy column, kept in sync with `image`
  plan          Plan       @default(free)
  planExpiry    DateTime?
  role          Role       @default(user)
  targetYear    String?
  targetRank    Int?
  currentStatus String?
  phone         String?    @unique
  phoneVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLoginAt   DateTime?

  attempts      Attempt[]
  activity      Activity[]
  payments      Payment[]
  upiPayments   UpiPayment[]
  entitlements  Entitlement[]
  accounts      Account[]
  sessions      Session[]

  @@index([plan])
  @@index([createdAt])
}

// Per exam+subject access record. A user may hold several entitlements (e.g.
// GATE Mining + a future PSU discipline). `tier` mirrors the Plan enum so the
// same pro/premium semantics apply per track. The global User.plan is kept in
// sync only for the currently-live GATE Mining track so existing gating keeps
// working; broader gating off entitlements is a follow-up.
model Entitlement {
  id        String    @id @default(cuid())
  userId    String
  exam      String                      // ExamTrack code: GATE | PSU | STATE | DIPLOMA
  subject   String                      // subject slug within the exam (e.g. "mining")
  tier      Plan                        // pro | premium (free never stored)
  source    String    @default("grant") // grant | upi | razorpay
  expiry    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exam, subject])
  @@index([exam, subject])
}

model Attempt {
  id          String       @id @default(cuid())
  userId      String
  kind        AttemptKind
  refId       String                                   // e.g. "mock-01" or "pyq-2023"
  refTitle    String
  score       Float
  total       Float
  correct     Int          @default(0)
  wrong       Int          @default(0)
  skipped     Int          @default(0)
  breakdown   Json                                     // per-subject scores
  answersJson Json                                     // raw answers map (for review)
  durationSec Int          @default(0)
  takenAt     DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt(sort: Desc)])
  @@index([kind, refId])
}

model Activity {
  id      String   @id @default(cuid())
  userId  String
  type    String                       // e.g. "login", "mock_submit", "plan_upgrade"
  payload Json
  ts      DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ts(sort: Desc)])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  razorpayOrderId  String   @unique
  razorpayPaymentId String? @unique
  amount           Int                       // in paise
  currency         String   @default("INR")
  plan             Plan
  exam             String?                   // ExamTrack code attribution (e.g. "GATE")
  subject          String?                   // subject slug attribution (e.g. "mining")
  periodMonths     Int      @default(1)
  status           String   @default("created") // created | captured | failed | refunded
  raw              Json?
  createdAt        DateTime @default(now())
  capturedAt       DateTime?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// Manual UPI claim flow — user pays via UPI app, submits the UTR / reference
// number here, an admin verifies against their UPI app and approves to flip
// the user's plan. Zero gateway dependency — used while Razorpay KYC is
// pending or for users who prefer direct UPI.
model UpiPayment {
  id            String          @id @default(cuid())
  userId        String
  plan          Plan
  exam          String?                          // ExamTrack code (e.g. "GATE")
  subject       String?                          // subject slug (e.g. "mining")
  amountPaise   Int                              // 49900 = ₹499
  periodMonths  Int             @default(18)
  payerName     String?                          // full name the user paid with
  payerPhone    String?                          // contact + reconciliation key (UPI payer)
  payerEmail    String?                          // contact email
  upiTxnRef     String?                          // legacy UPI reference (no longer collected)
  upiApp        String?                          // PhonePe | GPay | Paytm | BHIM | Other
  payerNote     String?                          // optional message from user
  status        UpiClaimStatus  @default(pending)
  adminNote     String?                          // reason if rejected
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@index([payerPhone])
}

// ---------- NextAuth.js tables ----------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// WhatsApp / SMS OTP codes. We store a bcrypt hash, never the raw code.
model OtpCode {
  id         String   @id @default(cuid())
  phone      String                                  // E.164 without '+', e.g. 919470126588
  codeHash   String                                  // bcrypt hash of the 6-digit code
  channel    String   @default("whatsapp")          // whatsapp | sms
  attempts   Int      @default(0)                   // verification attempts used
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  ip         String?

  @@index([phone, createdAt(sort: Desc)])
}

