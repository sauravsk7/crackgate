{
  "name": "crackgate-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev":         "echo 'Use npm run dev:web (port 3000) or dev:api (port 3001)'",
    "dev:web":     "npm run dev -w apps/frontend",
    "dev:api":     "npm run dev -w apps/backend",
    "build":       "npm run db:generate && npm run build --workspaces --if-present",
    "build:web":   "npm run db:generate && npm run build -w apps/frontend",
    "build:api":   "npm run db:generate && npm run build -w apps/backend",
    "lint":        "npm run lint --workspaces --if-present",
    "db:generate": "npm run generate -w @crackgate/database",
    "db:migrate":  "npm run migrate  -w @crackgate/database",
    "db:deploy":   "npm run deploy   -w @crackgate/database",
    "db:studio":   "npm run studio   -w @crackgate/database",
    "db:seed":     "npm run seed     -w @crackgate/database"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  }
}
