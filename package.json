{
  "name": "crackgate-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run db:generate && npm run build -w apps/web",
    "build:web": "npm run db:generate && npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run generate -w @crackgate/database",
    "db:migrate": "npm run migrate  -w @crackgate/database",
    "db:deploy": "npm run deploy   -w @crackgate/database",
    "db:studio": "npm run studio   -w @crackgate/database",
    "db:seed": "npm run seed     -w @crackgate/database",
    "build:mocks": "npx tsx scripts/build_mocks.ts",
    "build:mocks:force": "npx tsx scripts/build_mocks.ts --force",
    "build:mocks:one": "npx tsx scripts/build_mocks.ts --only=",
    "build:gg:practice": "npx tsx scripts/build_gg_practice.ts",
    "build:gg:mocks": "npx tsx scripts/build_gg_mocks.ts",
    "build:gg:mocks:force": "npx tsx scripts/build_gg_mocks.ts --force"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@prisma/client": "6.19.3"
  }
}
