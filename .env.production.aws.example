# ─────────────────────────────────────────────────────────────────────────────
# CrackGate — AWS production env template (for docker-compose.aws.yml)
#
# On the EC2 box, this file is NOT hand-edited. It's fetched from
# AWS Secrets Manager by scripts/ec2-bootstrap.sh:
#
#   aws secretsmanager get-secret-value \
#     --region ap-south-1 --secret-id crackgate/prod/env \
#     --query SecretString --output text > /opt/crackgate/.env.production
#
# Use this file ONLY to seed the secret the first time:
#
#   aws secretsmanager create-secret \
#     --name crackgate/prod/env \
#     --region ap-south-1 \
#     --secret-string file://.env.production
#
# Rotate by updating the secret + re-running ec2-bootstrap.sh step 5, or:
#   aws ssm send-command --document-name AWS-RunShellScript \
#     --parameters 'commands=["systemctl restart crackgate.service"]' \
#     --targets "Key=tag:Name,Values=crackgate-prod"
#
# Every value marked CHANGE_ME must be set. Never commit the filled file.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS account / region ────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=CHANGE_ME_12_DIGITS

# ── ECR (set by GitHub Actions deploy, but ECR_REGISTRY needed at bootstrap) ─
# ECR_REGISTRY format: <acct>.dkr.ecr.<region>.amazonaws.com
ECR_REGISTRY=CHANGE_ME.dkr.ecr.ap-south-1.amazonaws.com
ECR_REPO=${ECR_REGISTRY}/crackgate-web
# IMAGE_TAG is rewritten by the deploy workflow on every push.
IMAGE_TAG=latest

# ── Domain + TLS ────────────────────────────────────────────────────────────
DOMAIN=crackgate.in
ACME_EMAIL=admin@crackgate.in

# ── CSRF (Origin header check — trusted origin for API POST/PATCH/DELETE) ──
# Comma-separate multiple origins if www is also used. Must match AUTH_URL.
APP_ORIGIN=https://crackgate.in

# ── RDS (db.t4g.micro Postgres 16, private subnet) ──────────────────────────
# Endpoint shown in the RDS console — e.g. crackgate-prod.abc123.ap-south-1.rds.amazonaws.com
RDS_HOST=CHANGE_ME.ap-south-1.rds.amazonaws.com
RDS_PORT=5432

# Postgres credentials.
# Password rules: hex/alnum only (no @ : / ? # + = &) — Prisma's URL parser
# trips on URL-special chars and we concat the DSN in docker-compose.aws.yml.
# Generate: openssl rand -hex 32
POSTGRES_DB=crackgate
POSTGRES_USER=crackgate
POSTGRES_PASSWORD=CHANGE_ME_HEX_64_CHARS

# NOTE: DATABASE_URL and DIRECT_URL are built inside docker-compose.aws.yml.
#   - web container → pgbouncer:5432 (?pgbouncer=true&connection_limit=1)
#   - prisma migrate → RDS_HOST directly (DDL needs single session)
# Do NOT set DATABASE_URL / DIRECT_URL here.

# ── S3 buckets (created in ap-south-1, EC2 IAM role grants access) ──────────
UPLOADS_BUCKET=crackgate-uploads
BACKUP_BUCKET=crackgate-backups

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
AUTH_SECRET=CHANGE_ME_BASE64_48_BYTES
AUTH_URL=https://crackgate.in

# ── Google OAuth ────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ENABLED=1
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Founder / admin console ─────────────────────────────────────────────────
# Comma-separated emails that get role=admin on login (unlocks /admin, the
# plan switcher, and all locked mocks/AITS). Runtime var — no image rebuild.
ADMIN_EMAILS=

# ── Razorpay (LIVE keys!) ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_CHANGE_ME

# ── Manual UPI fallback (optional) ──────────────────────────────────────────
NEXT_PUBLIC_UPI_VPA=
NEXT_PUBLIC_UPI_PAYEE_NAME=CrackGate

# ── WhatsApp (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_ENABLED=0
NEXT_PUBLIC_WHATSAPP_NUMBER=919470126588
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=

# ── Resend (transactional & newsletter email) ────────────────────────────────
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=support@crackgate.in

# ── Redis (for BullMQ background jobs — use ElastiCache for production) ────
REDIS_URL=redis://redis:6379

# ── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
