# ===== Dev tools =====
# Set to "1" in local dev to enable the bottom-left plan-switcher widget.
# Leave empty in production. The server endpoint stays admin-only either way.
NEXT_PUBLIC_DEV_TOOLS="1"

# Deployment environment. "staging" makes the app emit a noindex robots tag so
# staging.crackgate.in is never indexed. Leave as "production" (or unset) for prod.
NEXT_PUBLIC_SITE_ENV="production"

# ===== Database =====
# Local dev: docker run -e POSTGRES_PASSWORD=pg -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:pg@localhost:5432/crackgate?schema=public"

# ===== NextAuth =====
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ===== Google sign-in (direct OAuth, no Cognito) =====
# Get credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI to allow-list in Google: http://localhost:3000/api/auth/callback/google
# Production redirect URI:                https://crackgate.in/api/auth/callback/google
NEXT_PUBLIC_GOOGLE_ENABLED=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===== Sign-in provider toggles =====
# WhatsApp OTP login tab. Defaults to ON. Set to "0" in production to show
# Google-only on the /login page (WhatsApp chat button + community link are
# unaffected — those use NEXT_PUBLIC_WHATSAPP_NUMBER below).
NEXT_PUBLIC_WHATSAPP_ENABLED="1"

# ===== Razorpay =====
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="set-this-in-razorpay-dashboard"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"

# ===== Manual UPI (Tier-0 payments — works without a gateway) =====
# Your UPI VPA (e.g. yourname@okhdfcbank, yourbusiness@paytm). The QR code and
# UPI deep-link on /pay/upi are built from this. Leave blank to disable the
# manual UPI flow.
NEXT_PUBLIC_UPI_VPA=""
NEXT_PUBLIC_UPI_PAYEE_NAME="CrackGate"

# ===== AWS SES (for transactional email) =====
AWS_REGION="ap-south-1"
SES_FROM_EMAIL="noreply@crackgate.in"

# ===== Observability =====
SENTRY_DSN=""
# Browser DSN (inlined into client bundle at build time). Can equal SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ===== WhatsApp =====
# Public number for the floating chat button (E.164, no '+'). e.g. 919470126588
NEXT_PUBLIC_WHATSAPP_NUMBER="919470126588"
# Optional community/group invite link
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL="https://chat.whatsapp.com/REPLACE_WITH_YOUR_INVITE"

# WhatsApp Business Cloud API (Meta) — needed for OTP login + transactional sends
# Get from: https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
# Random string you choose; paste the SAME value into Meta when configuring the webhook
WHATSAPP_VERIFY_TOKEN="pick-any-long-random-string"
# Approved template names (created in Meta WhatsApp Manager → Message Templates)
WHATSAPP_TEMPLATE_OTP="crackgate_otp"
WHATSAPP_TEMPLATE_PAYMENT="crackgate_payment_success"

