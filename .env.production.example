# ─────────────────────────────────────────────────────────────────
# CrackGate — production env template
# Copy to .env.production on the VPS:  cp .env.production.example .env.production
# Fill in EVERY value marked CHANGE_ME. Never commit .env.production.
# ─────────────────────────────────────────────────────────────────

# ── Domain + TLS ────────────────────────────────────────────────
DOMAIN=crackgate.in
ACME_EMAIL=admin@crackgate.in

# ── CSRF (Origin header check — trusted origin for API POST/PATCH/DELETE) ──
# Comma-separate multiple origins if www is also used. Must match AUTH_URL.
APP_ORIGIN=https://crackgate.in

# ─ Postgres (used by both `db` and `web` services) ────────────
# MUST be hex/alnum only — no +, /, =, @, :, ?, # — because we build
# DATABASE_URL by string concat in docker-compose.yml and any URL-special
# character would break Prisma's URL parser.
# Generate:  openssl rand -hex 32
POSTGRES_DB=crackgate
POSTGRES_USER=crackgate
POSTGRES_PASSWORD=CHANGE_ME_HEX_64_CHARS

# ── NextAuth ───────────────────────────────────────────────────
# Generate: openssl rand -base64 48
AUTH_SECRET=CHANGE_ME_BASE64_48_BYTES
AUTH_URL=https://crackgate.in

# ── Google OAuth ───────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ENABLED=1
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Founder / admin console ────────────────────────────────────
# Comma-separated emails that get role=admin on login (unlocks /admin,
# the plan switcher, and all locked mocks/AITS). Runtime var — no rebuild.
ADMIN_EMAILS=

# ── Razorpay (LIVE keys for production!) ───────────────────────
RAZORPAY_KEY_ID=rzp_live_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_CHANGE_ME
# ── Manual UPI (Tier-0 — no gateway / KYC needed) ───────────────
# Set your UPI VPA below. Users see a QR + deep-link on /pay/upi, pay you
# directly, then submit the UTR for manual approval at /admin/upi.
# Leave blank to hide the manual UPI flow.
NEXT_PUBLIC_UPI_VPA=
NEXT_PUBLIC_UPI_PAYEE_NAME=CrackGate
# ── WhatsApp (optional; set =1 to enable) ──────────────────────
NEXT_PUBLIC_WHATSAPP_ENABLED=0
NEXT_PUBLIC_WHATSAPP_NUMBER=919470126588
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=

# ── Redis (for BullMQ background jobs) ─────────────────────────
# On docker compose: the `redis` service is auto-discoverable at redis://redis:6379.
# On single-server: run redis-server locally and set REDIS_URL=redis://localhost:6379.
# On AWS: point to your ElastiCache Redis endpoint (or omit and jobs run inline).
REDIS_URL=redis://redis:6379

# ── Observability (optional) ───────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
